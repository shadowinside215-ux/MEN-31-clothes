{
  "entities": {
    "ClothingItem": {
      "title": "Clothing Item",
      "description": "A clothing item in the catalog",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "The name of the item" },
        "price": { "type": "number", "description": "The price of the item" },
        "category": { "type": "string", "description": "The category of the item" },
        "imageUrl": { "type": "string", "description": "The URL of the item image" },
        "sizes": { "type": "array", "items": { "type": "string" }, "description": "Available sizes" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" }
      },
      "required": ["name", "price", "category", "imageUrl", "sizes"]
    },
    "CategoryConfig": {
      "title": "Category Configuration",
      "description": "Configuration for a category, such as its cover image",
      "type": "object",
      "properties": {
        "categoryName": { "type": "string", "description": "The name of the category" },
        "coverImageUrl": { "type": "string", "description": "The URL of the category cover image" }
      },
      "required": ["categoryName", "coverImageUrl"]
    }
  },
  "firestore": {
    "/items/{itemId}": {
      "schema": "ClothingItem",
      "description": "Collection of clothing items"
    },
    "/categories/{categoryId}": {
      "schema": "CategoryConfig",
      "description": "Collection of category configurations"
    }
  }
}
