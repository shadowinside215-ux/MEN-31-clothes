rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: items
    // Document ID: auto-generated
    // Fields:
    //   - name: string (required) - Item name
    //   - price: number (required) - Item price
    //   - category: string (required) - Item category
    //   - imageUrl: string (required) - Item image URL
    //   - sizes: list (required) - Available sizes
    //   - createdAt: timestamp (optional) - Creation timestamp
    //
    // ===============================================================

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
             (request.auth.token.email == "dragonballsam86@gmail.com" && request.auth.token.email_verified == true);
    }

    function isValidItem(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.price is number && data.price >= 0 &&
             data.category is string && data.category.size() > 0 &&
             data.imageUrl is string && data.imageUrl.matches("^https://.*") &&
             data.sizes is list && data.sizes.size() > 0;
    }

    match /items/{itemId} {
      allow read: if true; // Public catalog
      allow create, update, delete: if isAdmin();
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
  }
}
